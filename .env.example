# SEO Pulse Environment Variables Template
# When deploying publicly, copy this to .env and add your real keys

# Your Google Gemini API Key from https://aistudio.google.com/app/apikey
# For Vite apps, use VITE_ prefix for client-side access
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) If you set up a real Firebase backend later:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
